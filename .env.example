# Discord bot token from the Discord Developer Portal.
# Never commit your real token. Put it in .env locally and Railway Variables in production.
DISCORD_TOKEN=

# Channel where approval embeds should appear.
APPROVAL_CHANNEL_ID=

# Optional comma-separated list. Leave blank to watch every channel the bot can read.
SOURCE_CHANNEL_IDS=

# Gemini API key from Google AI Studio.
# Never commit your real key. Put it in .env locally and Railway Variables in production.
GEMINI_API_KEY=

# Optional. Defaults to gemini-2.5-flash-lite when blank.
# The Google quickstart sometimes uses gemini-flash-latest; either can be tested.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional local path. On Railway, set DATABASE_PATH=/data/video-router.sqlite after mounting a volume to /data.
DATABASE_PATH=

# Railway provides PORT automatically. Locally, use 3001 if 3000 is already occupied.
PORT=3000

# Optional. Set true for message-filter checkpoint logs while testing.
DEBUG_VIDEO_ROUTER=false

# Destination routes. Keep this on one line for .env parsing.
# Preferred array form:
# CHANNEL_MAP_JSON=[{"key":"ai","channelId":"123","description":"AI tools, models, agents, automation"},{"key":"uncategorized","channelId":"456","description":"Fallback when no category clearly fits"}]
# Shortcut object form also works:
# CHANNEL_MAP_JSON={"ai":"123","uncategorized":"456"}
CHANNEL_MAP_JSON=[]
